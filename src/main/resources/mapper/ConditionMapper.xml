<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.panda.maven.onlineexamdemo.mapper.ConditionMapper">
    <select id="list" resultType="com.panda.maven.onlineexamdemo.dto.ConditionDto">
        select * from exam_condition where role = 'student'
    </select>
    <select id="listByCondition" resultType="com.panda.maven.onlineexamdemo.dto.ConditionDto">
        select distinct ec.username,u.name,ec.subject from exam_condition ec,user u
        <where>
            u.role = 'student'
                 <if test="request.name != null and request.name != ''">
                     and u.name = like concat('%',#{request.name},'%')
                 </if>
                <if test="request.username != null and request.username != ''">
                     and ec.username = like concat('%',#{request.username},'%')
                 </if>
        </where>
    </select>
    <select id="selectByUserName" resultType="com.panda.maven.onlineexamdemo.entity.Condition">
        select * from exam_condition where username = #{username} and subject = #{courseName} order by id desc
    </select>
    <select id="selectBycourseName" resultType="java.lang.String">
        select course_name from course where course_name = #{courseName}
    </select>
</mapper>