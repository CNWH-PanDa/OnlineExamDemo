<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.panda.maven.onlineexamdemo.mapper.UserMapper">

    <select id="selectByUsernameAndPassword" resultType="com.panda.maven.onlineexamdemo.entity.User">
        select * from user where username = #{username} and password = #{password}
    </select>
    <select id="getByUsername" resultType="com.panda.maven.onlineexamdemo.entity.User">
        select * from user where username = #{username}
    </select>
</mapper>