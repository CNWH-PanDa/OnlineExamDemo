<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.panda.maven.onlineexamdemo.mapper.UserMapper">
    <insert id="insertByIds">
        insert into user_course (uid,cid) values
        <foreach collection="courseIds" item="item" separator=",">
            (#{id}, #{item})
        </foreach>
    </insert>
    <update id="change">
        update user
        <set>
            <if test="name != null and name != ''">
                name = #{name},
            </if>
            <if test="gender != null and gender != ''">
                gender = #{gender},
            </if>
            <if test="phone != null and phone != ''">
                phone = #{phone},
            </if>
            <if test="college != null and college != ''">
                college = #{college},
            </if>
        </set>
        where username = #{username}
    </update>
    <delete id="deleteById">
        delete from user_course where uid = #{courseId}
    </delete>
    <select id="selectByUsernameAndPassword" resultType="com.panda.maven.onlineexamdemo.entity.User">
        select * from user where username = #{username} and password = #{password}
    </select>
    <select id="getByUsername" resultMap="UserMap">
        SELECT u.*, c.course_id, c.course_name, c.create_time
        FROM user u
        LEFT JOIN user_course uc ON u.course = uc.uid
        LEFT JOIN course c ON uc.cid = c.course_id
        WHERE u.username = #{username}
    </select>
    <select id="getByUsername1" resultType="com.panda.maven.onlineexamdemo.entity.User">
        select * from user where username = #{username}
    </select>
<!--    <select id="getByCourseId" resultType="com.panda.maven.onlineexamdemo.entity.Course">-->
<!--        select c.* from course c-->
<!--        inner join user_course uc on uc.cid = c.course_id-->
<!--        where uc.uid = #{courseId}-->
<!--    </select>-->
    <resultMap id="UserMap" type="com.panda.maven.onlineexamdemo.dto.UserDto">
        <id column="username" property="username"/>
        <result column="gender" property="gender"/>
        <result column="phone" property="phone"/>
        <result column="name" property="name"/>
        <result column="college" property="college"/>
        <result column="role" property="role"/>
        <collection property="courses"
                    ofType="com.panda.maven.onlineexamdemo.entity.Course">
            <id column="course_id" property="courseId"/>
            <result column="course_name" property="courseName"/>
            <result column="create_time" property="createTime"/>
        </collection>
    </resultMap>
</mapper>